<script>
// ==================== VERİ SETİ ====================
// Kaynaklar: TFF resmi raporları, Transfermarkt Fair Play tabloları, NTV Spor, AA, FotMob, ESPN, Mackolik
// 2025-26: İlk yarı verileri (sezon devam ediyor), 38 maç projeksiyonu yapılmıştır

const seasons = ['2021-22', '2022-23', '2023-24', '2024-25', '2025-26*'];
const teams = ['Galatasaray', 'Fenerbahçe', 'Beşiktaş', 'Trabzonspor', 'Başakşehir'];

const teamColors = {
    'Galatasaray':  { bg: 'rgba(253, 185, 19, 0.8)',  border: '#FDB913', light: 'rgba(253, 185, 19, 0.15)' },
    'Fenerbahçe':   { bg: 'rgba(0, 32, 91, 0.8)',     border: '#00205B', light: 'rgba(0, 32, 91, 0.15)' },
    'Beşiktaş':     { bg: 'rgba(80, 80, 80, 0.8)',    border: '#505050', light: 'rgba(80, 80, 80, 0.15)' },
    'Trabzonspor':  { bg: 'rgba(106, 0, 50, 0.8)',    border: '#6A0032', light: 'rgba(106, 0, 50, 0.15)' },
    'Başakşehir':   { bg: 'rgba(242, 101, 34, 0.8)',  border: '#F26522', light: 'rgba(242, 101, 34, 0.15)' },
};

const teamDots = {
    'Galatasaray': '#FDB913',
    'Fenerbahçe': '#00205B',
    'Beşiktaş': '#505050',
    'Trabzonspor': '#6A0032',
    'Başakşehir': '#F26522',
};

// Sarı Kart verileri (sezon başına)
// Kaynaklar: TFF 2021-22, 2022-23, 2023-24 resmi raporları; Transfermarkt & NTV Spor kart raporları; TGRT Haber 2025-26
const yellowCards = {
    'Galatasaray':  [72, 64, 65, 68, 62],
    'Fenerbahçe':   [80, 91, 88, 82, 83],
    'Beşiktaş':     [91, 84, 91, 85, 85],
    'Trabzonspor':  [58, 71, 63, 66, 58],
    'Başakşehir':   [70, 68, 76, 72, 69],
};

// Kırmızı Kart verileri (direkt kırmızı + çift sarıdan kırmızı)
// Kaynaklar: TFF raporları, Transfermarkt, AA, NTV Spor, FotMob
const redCards = {
    'Galatasaray':  [3, 1, 1, 2, 4],
    'Fenerbahçe':   [5, 5, 5, 3, 2],
    'Beşiktaş':     [10, 5, 4, 6, 7],
    'Trabzonspor':  [3, 4, 1, 4, 7],
    'Başakşehir':   [4, 3, 5, 3, 4],
};

// Penaltı verileri (lehte kazanılan penaltılar)
// Kaynaklar: NTV, AA penaltı dosyaları; Transfermarkt penaltı istatistikleri; FotMob; TGRT Haber
const penalties = {
    'Galatasaray':  [12, 12, 8, 8, 5],
    'Fenerbahçe':   [12, 17, 12, 7, 10],
    'Beşiktaş':     [8, 10, 7, 7, 8],
    'Trabzonspor':  [11, 9, 6, 5, 10],
    'Başakşehir':   [6, 5, 5, 4, 4],
};

// Maç sayıları
const matches = {
    'Galatasaray':  [38, 38, 38, 38, 38],
    'Fenerbahçe':   [38, 38, 38, 38, 38],
    'Beşiktaş':     [38, 38, 38, 38, 38],
    'Trabzonspor':  [38, 38, 38, 38, 38],
    'Başakşehir':   [38, 38, 38, 38, 38],
};

// ==================== CHART OPTIONS ====================
Chart.defaults.color = '#9ca3b4';
Chart.defaults.borderColor = 'rgba(42, 46, 62, 0.5)';
Chart.defaults.font.family = "'Segoe UI', system-ui, sans-serif";

const tooltipStyle = {
    backgroundColor: '#1a1d28',
    titleColor: '#e8eaf0',
    bodyColor: '#9ca3b4',
    borderColor: '#2a2e3e',
    borderWidth: 1,
    cornerRadius: 8,
    padding: 12,
};

function makeDatasets(dataObj, useTeamColors = true) {
    return teams.map(team => ({
        label: team,
        data: dataObj[team],
        backgroundColor: teamColors[team].bg,
        borderColor: teamColors[team].border,
        borderWidth: 2,
        borderRadius: 4,
    }));
}

function makeLineDatasets(dataObj) {
    return teams.map(team => ({
        label: team,
        data: dataObj[team],
        borderColor: teamColors[team].border,
        backgroundColor: teamColors[team].light,
        borderWidth: 3,
        pointRadius: 5,
        pointHoverRadius: 8,
        pointBackgroundColor: teamColors[team].border,
        tension: 0.3,
        fill: false,
    }));
}

// ==================== CHARTS ====================

// 1. Yellow Bar Chart
new Chart(document.getElementById('yellowBarChart'), {
    type: 'bar',
    data: { labels: seasons, datasets: makeDatasets(yellowCards) },
    options: {
        responsive: true,
        maintainAspectRatio: false,
