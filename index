            --gs-secondary: #C8102E;
            --fb-primary: #FFED00;
            --fb-secondary: #00205B;
            --bjk-primary: #000000;
            --bjk-secondary: #FFFFFF;
            --ts-primary: #6A0032;
            --ts-secondary: #003DA5;
            --ibfk-primary: #F26522;
            --ibfk-secondary: #1B1464;
            --bg-dark: #0f1117;
            --bg-card: #1a1d28;
            --bg-card-hover: #22263a;
            --text-primary: #e8eaf0;
            --text-secondary: #9ca3b4;
            --accent: #4f8cff;
            --border: #2a2e3e;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            line-height: 1.6;
        }

        .hero {
            background: linear-gradient(135deg, #1a1d28 0%, #0f1117 50%, #1a1130 100%);
            padding: 48px 24px 32px;
            text-align: center;
            border-bottom: 1px solid var(--border);
        }

        .hero h1 {
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(90deg, #4f8cff, #a855f7, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 8px;
        }

        .hero .subtitle {
            color: var(--text-secondary);
            font-size: 1rem;
            margin-bottom: 16px;
        }

        .hero .badge {
            display: inline-block;
