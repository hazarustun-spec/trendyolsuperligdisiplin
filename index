        .sources {
            background: var(--bg-card);
            border-radius: 14px;
            padding: 24px;
            border: 1px solid var(--border);
            margin-top: 32px;
        }

        .sources h3 {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--accent);
        }

        .sources ul {
            list-style: none;
            padding: 0;
        }

        .sources li {
            padding: 6px 0;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .sources li a {
            color: var(--accent);
            text-decoration: none;
        }

        .sources li a:hover { text-decoration: underline; }

        .disclaimer {
            margin-top: 16px;
            padding: 12px 16px;
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 8px;
            font-size: 0.82rem;
            color: #f87171;
        }

        .tab-bar {
            display: flex;
            gap: 8px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .tab-btn {
            padding: 8px 18px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 0.88rem;
            font-weight: 500;
            transition: all 0.15s;
        }

        .tab-btn:hover { border-color: var(--accent); color: var(--text-primary); }
        .tab-btn.active {
            background: rgba(79, 140, 255, 0.15);
            border-color: var(--accent);
            color: var(--accent);
        }

        .stat-cards {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 12px;
            margin-bottom: 32px;
        }

        @media (max-width: 900px) {
            .stat-cards { grid-template-columns: repeat(2, 1fr); }
