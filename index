        .card h3 {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 16px;
            color: var(--text-secondary);
        }

        .chart-container {
            position: relative;
            width: 100%;
            height: 350px;
        }

        .chart-container.tall { height: 420px; }

        /* Summary Table */
        .summary-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.88rem;
        }

        .summary-table thead th {
            background: rgba(79, 140, 255, 0.1);
            padding: 10px 12px;
            text-align: center;
            font-weight: 600;
            color: var(--accent);
            border-bottom: 2px solid var(--border);
            white-space: nowrap;
        }

        .summary-table thead th:first-child { text-align: left; border-radius: 8px 0 0 0; }
        .summary-table thead th:last-child { border-radius: 0 8px 0 0; }

        .summary-table tbody td {
            padding: 10px 12px;
            text-align: center;
            border-bottom: 1px solid var(--border);
        }

        .summary-table tbody td:first-child {
            text-align: left;
            font-weight: 600;
        }

        .summary-table tbody tr:hover { background: var(--bg-card-hover); }

        .team-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .team-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            display: inline-block;
        }

        .highlight-max { color: #ef4444; font-weight: 700; }
        .highlight-min { color: #22c55e; font-weight: 700; }

        /* Info box */
        .info-box {
            background: rgba(79, 140, 255, 0.08);
            border: 1px solid rgba(79, 140, 255, 0.2);
            border-radius: 10px;
            padding: 18px 20px;
            margin-bottom: 24px;
            font-size: 0.88rem;
            color: var(--text-secondary);
